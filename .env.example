# =========================================================
# finrag — environment template. Copy to .env and fill in the secrets.
# =========================================================

# ---- SEC EDGAR access (required — SEC blocks requests without a real contact email) ----
# Format: <app-name>/<version> <your-email>
EDGAR_USER_AGENT=finrag/0.1 your-email@example.com

# ---- Allowed models per provider (comma-separated; drives validation) ----
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro
ANTHROPIC_MODELS=claude-haiku-4-5-20251001,claude-sonnet-4-6,claude-opus-4-7
OPENAI_MODELS=gpt-4.1-nano,gpt-4.1-mini,gpt-4.1,o3
NVIDIA_MODELS=meta/llama-3.3-70b-instruct,meta/llama-4-maverick-17b-128e-instruct,deepseek-ai/deepseek-v4-pro,nvidia/llama-3.3-nemotron-super-49b-v1

# ---- LLM provider switch ----
# Primary = NVIDIA NIM (free open-weight) for BOTH generation and judging.
# Gemini / Anthropic / OpenAI are backups
LLM_PROVIDER=nvidia
# Generator: Llama-3.3-70B — disciplined single-JSON output that reads the reported
# figure. (Eval-driven choice: llama-4-maverick was faster but over-reasoned on hard
# numeric items — leaked chain-of-thought + multiple JSON blocks and derived wrong
# values, breaking the strict Answer contract. Maverick remains a fast alt for
# non-strict use.)
LLM_MODEL=meta/llama-3.3-70b-instruct
# Judge: Nemotron-Super-49B — NVIDIA's reasoning/RL-tuned model; ≥ the generator on
# reasoning + instruction-following (so it judges reliably), emits clean JSON at
# temperature 0, and has generous free-tier rate limits for full eval runs.
# (DeepSeek-V4-Pro is more capable but free-tier 429-throttles on batch judging, so
# it can't sustain a 38-item run — left in NVIDIA_MODELS as a known option.)
# Backup judges: gemini / anthropic / openai.
LLM_JUDGE_PROVIDER=nvidia
LLM_JUDGE_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Used by NVIDIA embedding/rerank/safety services and the Wave 1d LLM provider.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ---- Embedding ----
EMBEDDING_PROVIDER=nvidia
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
EMBEDDING_DIM=1024
VOYAGE_API_KEY=
COHERE_API_KEY=

# ---- Reranker (Wave 3d) ----
RERANKER_PROVIDER=nvidia
RERANKER_MODEL=nvidia/rerank-qa-mistral-4b
RERANKER_BASE_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/reranking
JINA_API_KEY=
# COHERE_API_KEY reused above

# ---- Retrieval variants (Wave 3 — read by src/retrieve.py) ----
# Winning Wave 3 config: hybrid RRF (3c) + cross-encoder rerank (3d).
# Ablations: recall@10 dense 0.722 → hybrid 0.753 → hybrid+rerank 0.885.
# RETRIEVAL_MODE: dense (vector only) | lexical (FTS only) | hybrid (RRF fusion)
RETRIEVAL_MODE=hybrid
# RERANK_ENABLED: 1 to rerank a larger candidate pool down to top_k (Wave 3d)
RERANK_ENABLED=1
# Candidate pool size fetched before reranking.
RERANK_CANDIDATES=50
# QUERY_REWRITE: none | multi_query | hyde (Wave 3e). Default none — 3e showed
# rewriting only helps under-specified queries; metadata filtering already disambiguates.
QUERY_REWRITE=none
# Chunking (3a): fixed beat sentence_window/parent_doc on this table-heavy corpus.
CHUNK_STRATEGY=fixed

# ---- Vector + lexical store (Postgres + pgvector + tsvector FTS) ----
# Recommended: Neon free tier (3 GB, pgvector preinstalled, branching).
# Alternative: Supabase free tier — same connection string format.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/finrag?sslmode=require

# ---- Tracing (Wave 5) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Guardrails (Wave 6) ----
# NVIDIA NemoGuard uses NVIDIA_API_KEY.
NEMOGUARD_CONTENT_SAFETY_MODEL=nvidia/llama-3.1-nemoguard-8b-content-safety
NEMOGUARD_JAILBREAK_MODEL=nvidia/nemoguard-jailbreak-detect
# OPENAI_API_KEY remains available as the backup moderation provider.

# ---- Tools (Wave 4) ----
TAVILY_API_KEY=
