# =========================================================
# finrag — environment template. Copy to .env and fill in.
# =========================================================

# ---- LLM (3-provider switch; only the one matching LLM_PROVIDER must be set) ----
LLM_PROVIDER=gemini
# Per-provider model defaults can be overridden here.
LLM_MODEL=gemini-2.5-flash
# Judge LLM for eval (defaults to LLM_PROVIDER / LLM_MODEL if unset).
LLM_JUDGE_PROVIDER=gemini
LLM_JUDGE_MODEL=gemini-2.5-flash-lite

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Embedding ----
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768
VOYAGE_API_KEY=
COHERE_API_KEY=

# ---- Reranker ----
RERANKER_PROVIDER=jina
RERANKER_MODEL=jina-reranker-v2-base-multilingual
JINA_API_KEY=
# COHERE_API_KEY reused above

# ---- Vector store ----
CHROMA_PATH=./.chroma

# ---- Tracing (Wave 5) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
