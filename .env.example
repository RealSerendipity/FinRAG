# =========================================================
# finrag — environment template. Copy to .env and fill in.
# =========================================================

# ---- SEC EDGAR access (required — SEC blocks requests without a real contact email) ----
# Format: <app-name>/<version> <your-email>
EDGAR_USER_AGENT=finrag/0.1 your-email@example.com

# ---- Allowed models per provider (comma-separated; drives validation) ----
# Blank LLM_MODEL / LLM_JUDGE_MODEL defaults to the first value in the matching list below.
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro
ANTHROPIC_MODELS=claude-haiku-4-5-20251001,claude-sonnet-4-6,claude-opus-4-7
OPENAI_MODELS=gpt-4.1-nano,gpt-4.1-mini,gpt-4.1
NVIDIA_MODELS=meta/llama-3.3-70b-instruct,meta/llama-4-maverick-17b-128e-instruct,deepseek-ai/deepseek-v4-pro,nvidia/llama-3.3-nemotron-super-49b-v1

# ---- LLM provider switch (only the one matching LLM_PROVIDER must be set) ----
# Wired providers: nvidia (primary) | gemini | anthropic | openai (backups)
LLM_PROVIDER=nvidia
# Generator: disciplined single-JSON output that reads the reported figure.
# (llama-4-maverick is faster but over-reasons on hard numeric items.)
LLM_MODEL=meta/llama-3.3-70b-instruct
# Judge LLM — STRONGER than the generator for reliable verdicts, with generous
# free-tier rate limits for full eval runs (nemotron-super-49b is reasoning/RL-tuned
# ≥ the 70B generator). DeepSeek-V4-Pro is more capable but 429-throttles on batch
# judging. Switch LLM_JUDGE_PROVIDER to gemini/anthropic/openai as backup.
LLM_JUDGE_PROVIDER=nvidia
LLM_JUDGE_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Used by NVIDIA embedding/rerank/safety services and the Wave 1d LLM provider.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ---- Embedding ----
EMBEDDING_PROVIDER=nvidia
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
EMBEDDING_DIM=1024
VOYAGE_API_KEY=
COHERE_API_KEY=

# ---- Reranker (Wave 3d) ----
RERANKER_PROVIDER=nvidia
# nv-rerankqa-mistral-4b-v3 may not be provisioned for every account; the
# retrieval endpoint serves rerank-qa-mistral-4b.
RERANKER_MODEL=nvidia/rerank-qa-mistral-4b
RERANKER_BASE_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/reranking
JINA_API_KEY=

# ---- Retrieval variants (Wave 3 — read by src/retrieve.py) ----
# RETRIEVAL_MODE: dense | lexical | hybrid (RRF fusion of vector + FTS)
RETRIEVAL_MODE=dense
RERANK_ENABLED=0
RERANK_CANDIDATES=50
# COHERE_API_KEY reused above

# ---- Vector + lexical store (Postgres + pgvector + tsvector FTS) ----
# Recommended: Neon free tier (3 GB, pgvector preinstalled, branching).
# Alternative: Supabase free tier — same connection string format.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/finrag?sslmode=require

# ---- Tracing (Wave 5) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Guardrails (Wave 6) ----
# NVIDIA NemoGuard uses NVIDIA_API_KEY.
NEMOGUARD_CONTENT_SAFETY_MODEL=nvidia/llama-3.1-nemoguard-8b-content-safety
NEMOGUARD_JAILBREAK_MODEL=nvidia/nemoguard-jailbreak-detect
# OPENAI_API_KEY remains available as the backup moderation provider.

# ---- Tools (Wave 4) ----
TAVILY_API_KEY=
