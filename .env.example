# =========================================================
# finrag — environment template. Copy to .env and fill in.
# =========================================================

# ---- LLM provider switch (only the one matching LLM_PROVIDER must be set) ----
# Currently wired (Wave 0): gemini | anthropic | openai
# Wave 1d planned:          openrouter   (Llama / Qwen / DeepSeek via cloud router)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
# Judge LLM for eval (defaults to LLM_PROVIDER / LLM_MODEL if unset)
LLM_JUDGE_PROVIDER=gemini
LLM_JUDGE_MODEL=gemini-2.5-flash-lite

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=  # Wave 1d (not yet wired)

# ---- Embedding ----
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768
VOYAGE_API_KEY=
COHERE_API_KEY=

# ---- Reranker ----
RERANKER_PROVIDER=jina
RERANKER_MODEL=jina-reranker-v2-base-multilingual
JINA_API_KEY=
# COHERE_API_KEY reused above

# ---- Vector + lexical store (Postgres + pgvector + tsvector FTS) ----
# Recommended: Neon free tier (3 GB, pgvector preinstalled, branching).
# Alternative: Supabase free tier — same connection string format.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/finrag?sslmode=require

# ---- Tracing (Wave 5) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Guardrails (Wave 6) ----
# Reuses OPENAI_API_KEY for OpenAI Moderation API.
# Llama Guard, if enabled, is reached via OPENROUTER_API_KEY.

# ---- Tools (Wave 4) ----
TAVILY_API_KEY=
